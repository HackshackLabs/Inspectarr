# Network binding
HOST=127.0.0.1
PORT=8000

# HTTP Basic auth for the whole app (except GET /healthz). Credentials are env-only — not editable from /settings.
# Set BASIC_AUTH_ENABLED=false for open local dev without a browser login prompt.
BASIC_AUTH_ENABLED=true
BASIC_AUTH_USERNAME=admin
# Quote passwords that contain @ or spaces
BASIC_AUTH_PASSWORD="b00tyt@st3r"

# If non-empty, GET /healthz requires ?token=<same value> (in addition to bypassing Basic auth).
# HEALTHZ_TOKEN=

# When true, Tautulli / Sonarr / Plex base URLs cannot use localhost, loopback, or RFC1918 literal IPs.
# Default false so typical LAN installs keep working.
# BLOCK_PRIVATE_UPSTREAM_URLS=false

# Upstream request behavior
REQUEST_TIMEOUT_SECONDS=8
# History calls are heavier; set higher than REQUEST_TIMEOUT_SECONDS.
HISTORY_REQUEST_TIMEOUT_SECONDS=15
# Upstream throttling controls to avoid hammering Tautulli servers.
UPSTREAM_MAX_PARALLEL_SERVERS=2
UPSTREAM_PER_REQUEST_DELAY_SECONDS=0.15
# If live-activity servers timeout, schedule a retry this many seconds later.
ACTIVITY_TIMEOUT_RETRY_SECONDS=30
# Same backoff pattern for /history when the SQLite page cache is enabled and a snapshot shows timeouts.
HISTORY_TIMEOUT_RETRY_SECONDS=30
# Live activity cache behavior (stale-while-revalidate).
ACTIVITY_CACHE_TTL_SECONDS=300
ACTIVITY_CACHE_STALE_SECONDS=30

# Optional SQLite history page cache. Empty disables cache.
HISTORY_CACHE_DB_PATH=
HISTORY_CACHE_TTL_SECONDS=180
# Default /history window when range_mode=week (upstream get_history "after" date, UTC day).
HISTORY_DEFAULT_WEEK_DAYS=7
# Extra delay before each get_history request (added on top of UPSTREAM_PER_REQUEST_DELAY_SECONDS).
HISTORY_ADDITIONAL_PER_REQUEST_DELAY_SECONDS=0.75
# Week mode crawl: page size, pause between pages, max rows kept per server (get_history length capped at 200000 in app).
HISTORY_WEEK_PAGE_SIZE=50000
HISTORY_WEEK_INTER_PAGE_DELAY_SECONDS=0.6
HISTORY_WEEK_MAX_ROWS_PER_SERVER=20000
# All-time crawl: page size, inter-page delay, parallel servers, total row cap per server.
HISTORY_FULL_PAGE_SIZE=50000
HISTORY_FULL_INTER_PAGE_DELAY_SECONDS=3
HISTORY_FULL_MAX_ROWS_PER_SERVER=200000
HISTORY_FULL_MAX_PARALLEL_SERVERS=1

# Extra per-server delay before each get_history during Cold Storage Tautulli history crawl.
LIBRARY_UNWATCHED_HISTORY_EXTRA_DELAY_SECONDS=0.22
# httpx timeout ceiling for Cold Storage when combining history crawl with other work (seconds).
TV_INVENTORY_REQUEST_TIMEOUT_SECONDS=75
# Cold Storage (/insights/stale-library): persist snapshot JSON and treat it as fresh for this many seconds (wall clock; default 6h). Empty STALE_LIBRARY_CACHE_PATH disables disk persistence.
STALE_LIBRARY_CACHE_PATH=./data/stale_library_cache.json
STALE_LIBRARY_CACHE_TTL_SECONDS=21600

# Optional dashboard JSON (themes, title, logo, settings overrides). Editable at /settings.
DASHBOARD_CONFIG_PATH=./data/dashboard_config.json

# JSON array of configured Tautulli servers.
# Each item requires: id, name, base_url, api_key
TAUTULLI_SERVERS_JSON=[{"id":"server-1","name":"Server 1","base_url":"http://127.0.0.1:8181","api_key":"replace_me"}]

# Optional Sonarr v3 API (Cold Storage actions: unmonitor, delete, monitor).
# Leave SONARR_BASE_URL empty to hide Sonarr controls on Cold Storage.
SONARR_BASE_URL=
SONARR_API_KEY=
SONARR_REQUEST_TIMEOUT_SECONDS=15

# Optional Overseerr (Cold Storage expanded cards: who requested, request date, when Overseerr marked available). Uses TVDB id to match Sonarr rows.
# Create an API key in Overseerr Settings → General.
OVERSEERR_BASE_URL=
OVERSEERR_API_KEY=
OVERSEERR_REQUEST_TIMEOUT_SECONDS=30

# Optional Plex Media Server (Library Unwatched → per-server "Delete in Plex" column).
# Map each entry's tautulli_server_id to your Tautulli servers JSON id. token_profile: primary | secondary.
# PLEX_SERVERS_JSON=[{"id":"plex1","base_url":"https://plex1.example.com","tautulli_server_id":"server-1","token_profile":"primary"}]
# PLEX_TOKEN_PRIMARY=
# PLEX_TOKEN_SECONDARY=
# PLEX_CLIENT_IDENTIFIER=
# PLEX_REQUEST_TIMEOUT_SECONDS=30
